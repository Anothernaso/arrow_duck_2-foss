[layer_names]

2d_physics/layer_1="default"
2d_physics/layer_2="lethal"
2d_physics/layer_3="kill_offscreen"

[physics]

2d/run_on_separate_thread=true
3d/run_on_separate_thread=true
common/physics_interpolation=true

[rendering]

