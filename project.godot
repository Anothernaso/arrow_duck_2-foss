; Engine configuration file.
; It's best edited using the editor UI and not directly,
; since the parameters that go here are not all obvious.
;
; Format:
;   [section] ; section goes between []
;   param=value ; assign values to parameters

config_version=5

[application]

config/name="Arrow Duck 2"
config/description="A game about a duck ducking from arrows."
config/version="3.4.0"
run/main_scene="uid://lgpl40m4r1b2"
config/features=PackedStringArray("4.7", "Forward Plus")
boot_splash/bg_color=Color(0.246792, 0.734962, 1, 1)
boot_splash/stretch_mode=4
boot_splash/image="uid://dsyqd0hyae2ea"
config/icon="uid://ghpw681ojcra"

[audio]

driver/driver="PipeWire"

[autoload]

AD_GlobalSettingManager="*uid://bj61lft1h8q4i"
AD_GlobalGameStateManager="*uid://ckum100t7knj4"
AD_GlobalMusicManager="*uid://bd1elsjt3hwrq"
AD_GlobalBackgroundManager="*uid://d3f75lbdadrmv"

[debug]

gdscript/warnings/untyped_declaration=2
gdscript/warnings/unsafe_property_access=2
gdscript/warnings/unsafe_method_access=2
gdscript/warnings/unsafe_call_argument=2
gdscript/warnings/unsafe_void_return=2
gdscript/warnings/missing_await=2

[display]

window/stretch/mode="viewport"
display_server/driver.linuxbsd="wayland"

[dotnet]

project/assembly_name="Arrow Duck 2"

[editor_plugins]

enabled=PackedStringArray("res://addons/anat_utils/plugin.cfg", "res://addons/arrow_duck_2/plugin.cfg")

[global_group]

player=""
cloud="A group for all clouds."
arrow="A group for all arrows"
lethal="A group for all things that should kill the player on impact."
projectile="A group for all projectiles. Note that arrows are not projectiles."
kill_offscreen="Bodies in this group will be killed upon exiting the `screen_area` node."

